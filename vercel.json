{
  "version": 2,
  "functions": {
    "api/webhook.js": {
      "maxDuration": 60
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors 'self' https://*.telegram.org https://web.telegram.org;"
        },
        {
          "key": "X-Frame-Options",
          "value": "ALLOW-FROM https://web.telegram.org/"
        }
      ]
    }
  ]
}
